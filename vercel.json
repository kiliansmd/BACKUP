{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "functions": {
    "app/api/parse-resume/route.ts": {
      "maxDuration": 30,
      "runtime": "nodejs20.x"
    },
    "app/api/get-resumes/route.ts": {
      "maxDuration": 10,
      "runtime": "nodejs20.x"
    },
    "app/api/resume/[id]/route.ts": {
      "maxDuration": 10,
      "runtime": "nodejs20.x"
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
